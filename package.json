{
  "name": "steam-electron-build",
  "version": "1.0.0",
  "description": "Ship any HTML5/WebGL game to Steam with Electron. One command locally, same command in CI. Steam overlay, achievements, saves and Steam Deck fixes included.",
  "license": "MIT",
  "author": "Alexander Thurn",
  "bin": {
    "steam-electron-build": "bin/cli.js"
  },
  "exports": {
    "./native": "./native/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "bin/",
    "runtime/",
    "native/",
    "assets/"
  ],
  "keywords": [
    "steam",
    "steamworks",
    "electron",
    "game",
    "html5",
    "webgl",
    "pixijs",
    "phaser",
    "steam-deck"
  ],
  "dependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.8.1",
    "steamworks.js": "^0.4.0"
  }
}
